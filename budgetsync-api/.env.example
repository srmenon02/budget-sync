# BudgetSync API environment
# Copy this file to .env and fill in real values.

# Runtime
ENVIRONMENT=development
ALLOWED_ORIGINS=

# Auth behavior
# Keep false in production. In development you may set true to bypass JWT checks.
DEV_AUTH_BYPASS=false
DEV_USER_ID=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=

# Database (if using Postgres in production)
DATABASE_URL=

# Optional integrations (future phases)
TELLER_APP_ID=
TELLER_ENVIRONMENT=
TELLER_TOKEN_ENCRYPTION_KEY=
TELLER_APPLICATION_ID=
TELLER_SIGNING_SECRET=
RESEND_API_KEY=
